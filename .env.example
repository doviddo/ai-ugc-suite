# ─── Google API Keys ───────────────────────────────────────────────────────────
# Gemini API key (used for photo/video analysis and TTS)
GEMINI_API_KEY=your_gemini_api_key_here

# Veo 3 API key (can be the same as Gemini if using same project)
VEO_API_KEY=your_veo_api_key_here

# TTS API key (can be the same as Gemini if using same project)
TTS_API_KEY=your_tts_api_key_here

# ─── TTS Voice ─────────────────────────────────────────────────────────────────
# Options: Puck (Male), Charon (Male), Aoede (Female), Leda (Female)
TTS_VOICE=Puck
